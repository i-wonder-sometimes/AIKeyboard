<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1A1A"
    android:paddingBottom="4dp">

    <!-- TOP UTILITY BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#111111"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnLayoutGrid"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_grid"
            android:contentDescription="Clipboard"
            android:scaleType="centerInside"
            android:background="@drawable/key_special_bg"
            android:layout_marginEnd="6dp"
            android:padding="8dp"/>

        <ImageButton
            android:id="@+id/btnGlobeTop"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_language"
            android:contentDescription="Switch Language"
            android:scaleType="centerInside"
            android:background="@drawable/key_special_bg"
            android:layout_marginEnd="6dp"
            android:padding="8dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvKeyboardLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Keyboard"
            android:textColor="#555555"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- CLIPBOARD PANEL (hidden by default) -->
    <LinearLayout
        android:id="@+id/panelCopiedText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D0D0D"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clipboard"
                android:textColor="#BBBBBB"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <ImageButton
                android:id="@+id/btnToggleTextScroll"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_expand"
                android:contentDescription="Expand"
                android:scaleType="centerInside"
                android:background="@android:color/transparent"
                android:padding="4dp"/>

        </LinearLayout>

        <ScrollView
            android:id="@+id/svCopiedText"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#1C1C1C"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvCopiedTextInline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:padding="10dp"/>

        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnGenerateAiReply"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Generate AI Reply"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/key_enter_bg"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnClosePanelInline"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Close"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:background="@drawable/key_special_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ALPHABET MODE -->
    <LinearLayout
        android:id="@+id/layoutAlphabetMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="2dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <Button android:id="@+id/keyA"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="a" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyZ"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="z" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyE"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="e" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyR"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="r" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyT"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="t" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyY"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="y" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyU"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="u" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyI"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="i" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyO"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="o" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyP"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="p" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="3dp">

            <Button android:id="@+id/keyQ"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="q" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyS"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="s" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyD"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="d" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyF"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="f" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyG"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="g" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyH"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="h" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyJ"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="j" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyK"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="k" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyL"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="l" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyM"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="m" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <ImageButton
                android:id="@+id/keyShift"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:src="@drawable/ic_shift"
                android:scaleType="centerInside"
                android:contentDescription="Shift"
                android:background="@drawable/key_special_bg"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="8dp"/>

            <Button android:id="@+id/keyW"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="w" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyX"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="x" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyC"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="c" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyV"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="v" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyB"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="b" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyN"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="n" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyApostrophe"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="'" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>

            <ImageButton
                android:id="@+id/keyBackspace"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:src="@drawable/ic_backspace"
                android:scaleType="centerInside"
                android:contentDescription="Backspace"
                android:background="@drawable/key_special_bg"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="8dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <Button
                android:id="@+id/keyNumbers"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.6"
                android:text="?123"
                android:textColor="#FFFFFF"
                android:background="@drawable/key_special_bg"
                android:textSize="11sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <ImageButton
                android:id="@+id/keyEmoji"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/ic_emoji"
                android:scaleType="centerInside"
                android:contentDescription="Emoji"
                android:background="@drawable/key_special_bg"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="8dp"/>

            <Button
                android:id="@+id/keySpace"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="4"
                android:text="English"
                android:textColor="#888888"
                android:background="@drawable/key_space_bg"
                android:textSize="12sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/keyPeriod"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.9"
                android:text="."
                android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg"
                android:textSize="18sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <ImageButton
                android:id="@+id/keyEnter"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.8"
                android:src="@drawable/ic_enter"
                android:scaleType="centerInside"
                android:contentDescription="Enter"
                android:background="@drawable/key_enter_bg"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="8dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- SYMBOL MODE -->
    <LinearLayout
        android:id="@+id/layoutSymbolMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="2dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <Button android:id="@+id/keyNum1"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="1" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyNum2"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="2" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyNum3"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="3" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyNum4"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="4" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyNum5"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="5" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyNum6"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="6" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyNum7"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="7" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyNum8"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="8" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyNum9"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="9" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyNum0"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="0" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <Button android:id="@+id/keyAt"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="@" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyHash"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="#" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyDollar"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="$" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyPercent"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="%" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyAmpersand"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="&amp;" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyAsterisk"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="*" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyExclaim"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="!" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyQuestion"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="?" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keySlash"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="/" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyBackslashSym"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="\\" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <Button android:id="@+id/keyParenOpen"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="(" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyParenClose"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text=")" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyBracketOpen"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="[" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyBracketClose"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="]" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyBraceOpen"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="{" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyBraceClose"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="}" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyMinus"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="-" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyPlus"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="+" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyEqual"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="=" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>
            <Button android:id="@+id/keyColon"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text=":" android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg" android:textSize="17sp"
                android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                android:padding="0dp" android:gravity="center"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <Button
                android:id="@+id/keyABC"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.6"
                android:text="ABC"
                android:textColor="#FFFFFF"
                android:background="@drawable/key_special_bg"
                android:textSize="11sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/keyQuote"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="&quot;"
                android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg"
                android:textSize="16sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/keySpaceSymbol"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="4"
                android:text="Space"
                android:textColor="#888888"
                android:background="@drawable/key_space_bg"
                android:textSize="12sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/keyComma"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.9"
                android:text=","
                android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg"
                android:textSize="18sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <ImageButton
                android:id="@+id/keyBackspaceSymbol"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.4"
                android:src="@drawable/ic_backspace"
                android:scaleType="centerInside"
                android:contentDescription="Backspace"
                android:background="@drawable/key_special_bg"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="8dp"/>

            <ImageButton
                android:id="@+id/keyEnterSymbol"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.4"
                android:src="@drawable/ic_enter"
                android:scaleType="centerInside"
                android:contentDescription="Enter"
                android:background="@drawable/key_enter_bg"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="8dp"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
