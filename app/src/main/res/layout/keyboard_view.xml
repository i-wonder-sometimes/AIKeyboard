<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1A1A"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#111111"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnLayoutGrid"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_grid"
            android:contentDescription="Clipboard / AI Reply"
            android:scaleType="centerInside"
            android:background="@drawable/key_special_bg"
            android:layout_marginEnd="6dp"
            android:padding="8dp"/>

        <ImageButton
            android:id="@+id/btnGlobeTop"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_language"
            android:contentDescription="Switch Language"
            android:scaleType="centerInside"
            android:background="@drawable/key_special_bg"
            android:layout_marginEnd="6dp"
            android:padding="8dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvKeyboardLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Keyboard"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            android:layout_marginEnd="2dp"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelCopiedText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D0D0D"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_grid"
                android:scaleType="centerInside"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clipboard"
                android:textColor="#BBBBBB"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <ImageButton
                android:id="@+id/btnToggleTextScroll"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_expand"
                android:contentDescription="Expand or collapse clipboard text"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"/>

        </LinearLayout>

        <ScrollView
            android:id="@+id/svCopiedText"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#1C1C1C"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvCopiedTextInline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:padding="10dp"/>

        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnGenerateAiReply"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Generate AI Reply"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/key_enter_bg"
                android:layout_marginEnd="6dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/btnClosePanelInline"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Close"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:background="@drawable/key_special_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:padding="0dp"/>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutAlphabetMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="2dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <Button android:id="@+id/keyA" style="@style/KeyStyle" android:text="a"/>
            <Button android:id="@+id/keyZ" style="@style/KeyStyle" android:text="z"/>
            <Button android:id="@+id/keyE" style="@style/KeyStyle" android:text="e"/>
            <Button android:id="@+id/keyR" style="@style/KeyStyle" android:text="r"/>
            <Button android:id="@+id/keyT" style="@style/KeyStyle" android:text="t"/>
            <Button android:id="@+id/keyY" style="@style/KeyStyle" android:text="y"/>
            <Button android:id="@+id/keyU" style="@style/KeyStyle" android:text="u"/>
            <Button android:id="@+id/keyI" style="@style/KeyStyle" android:text="i"/>
            <Button android:id="@+id/keyO" style="@style/KeyStyle" android:text="o"/>
            <Button android:id="@+id/keyP" style="@style/KeyStyle" android:text="p"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="3dp">

            <Button android:id="@+id/keyQ" style="@style/KeyStyle" android:text="q"/>
            <Button android:id="@+id/keyS" style="@style/KeyStyle" android:text="s"/>
            <Button android:id="@+id/keyD" style="@style/KeyStyle" android:text="d"/>
            <Button android:id="@+id/keyF" style="@style/KeyStyle" android:text="f"/>
            <Button android:id="@+id/keyG" style="@style/KeyStyle" android:text="g"/>
            <Button android:id="@+id/keyH" style="@style/KeyStyle" android:text="h"/>
            <Button android:id="@+id/keyJ" style="@style/KeyStyle" android:text="j"/>
            <Button android:id="@+id/keyK" style="@style/KeyStyle" android:text="k"/>
            <Button android:id="@+id/keyL" style="@style/KeyStyle" android:text="l"/>
            <Button android:id="@+id/keyM" style="@style/KeyStyle" android:text="m"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <ImageButton
                android:id="@+id/keyShift"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:src="@drawable/ic_shift"
                android:scaleType="centerInside"
                android:contentDescription="Shift"
                android:background="@drawable/key_special_bg"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="8dp"/>

            <Button android:id="@+id/keyW" style="@style/KeyStyle" android:text="w"/>
            <Button android:id="@+id/keyX" style="@style/KeyStyle" android:text="x"/>
            <Button android:id="@+id/keyC" style="@style/KeyStyle" android:text="c"/>
            <Button android:id="@+id/keyV" style="@style/KeyStyle" android:text="v"/>
            <Button android:id="@+id/keyB" style="@style/KeyStyle" android:text="b"/>
            <Button android:id="@+id/keyN" style="@style/KeyStyle" android:text="n"/>
            <Button android:id="@+id/keyApostrophe" style="@style/KeyStyle" android:text="'"/>

            <ImageButton
                android:id="@+id/keyBackspace"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:src="@drawable/ic_backspace"
                android:scaleType="centerInside"
                android:contentDescription="Backspace"
                android:background="@drawable/key_special_bg"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="8dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <Button
                android:id="@+id/keyNumbers"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.6"
                android:text="\&amp;?123"
                android:textColor="#FFFFFF"
                android:background="@drawable/key_special_bg"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <ImageButton
                android:id="@+id/keyEmoji"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/ic_emoji"
                android:scaleType="centerInside"
                android:contentDescription="Emoji"
                android:background="@drawable/key_special_bg"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="8dp"/>

            <Button
                android:id="@+id/keySpace"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="4"
                android:text="English"
                android:textColor="#888888"
                android:background="@drawable/key_space_bg"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.08"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/keyPeriod"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.9"
                android:text="."
                android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg"
                android:textSize="18sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <ImageButton
                android:id="@+id/keyEnter"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.8"
                android:src="@drawable/ic_enter"
                android:scaleType="centerInside"
                android:contentDescription="Enter"
                android:background="@drawable/key_enter_bg"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="8dp"/>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutSymbolMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="2dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <Button android:id="@+id/key1" style="@style/KeyStyle" android:text="1"/>
            <Button android:id="@+id/key2" style="@style/KeyStyle" android:text="2"/>
            <Button android:id="@+id/key3" style="@style/KeyStyle" android:text="3"/>
            <Button android:id="@+id/key4" style="@style/KeyStyle" android:text="4"/>
            <Button android:id="@+id/key5" style="@style/KeyStyle" android:text="5"/>
            <Button android:id="@+id/key6" style="@style/KeyStyle" android:text="6"/>
            <Button android:id="@+id/key7" style="@style/KeyStyle" android:text="7"/>
            <Button android:id="@+id/key8" style="@style/KeyStyle" android:text="8"/>
            <Button android:id="@+id/key9" style="@style/KeyStyle" android:text="9"/>
            <Button android:id="@+id/key0" style="@style/KeyStyle" android:text="0"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <Button android:id="@+id/keyAt"         style="@style/KeyStyle" android:text="@"/>
            <Button android:id="@+id/keyHash"        style="@style/KeyStyle" android:text="#"/>
            <Button android:id="@+id/keyDollar"      style="@style/KeyStyle" android:text="$"/>
            <Button android:id="@+id/keyPercent"     style="@style/KeyStyle" android:text="%"/>
            <Button android:id="@+id/keyAmpersand"   style="@style/KeyStyle" android:text="&amp;"/>
            <Button android:id="@+id/keyAsterisk"    style="@style/KeyStyle" android:text="*"/>
            <Button android:id="@+id/keyExclaim"     style="@style/KeyStyle" android:text="!"/>
            <Button android:id="@+id/keyQuestion"    style="@style/KeyStyle" android:text="?"/>
            <Button android:id="@+id/keySlash"       style="@style/KeyStyle" android:text="/"/>
            <Button android:id="@+id/keyBackslashSym" style="@style/KeyStyle" android:text="\"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <Button android:id="@+id/keyParen1"   style="@style/KeyStyle" android:text="("/>
            <Button android:id="@+id/keyParen2"   style="@style/KeyStyle" android:text=")"/>
            <Button android:id="@+id/keyBracket1" style="@style/KeyStyle" android:text="["/>
            <Button android:id="@+id/keyBracket2" style="@style/KeyStyle" android:text="]"/>
            <Button android:id="@+id/keyBrace1"   style="@style/KeyStyle" android:text="{"/>
            <Button android:id="@+id/keyBrace2"   style="@style/KeyStyle" android:text="}"/>
            <Button android:id="@+id/keyMinus"    style="@style/KeyStyle" android:text="-"/>
            <Button android:id="@+id/keyPlus"     style="@style/KeyStyle" android:text="+"/>
            <Button android:id="@+id/keyEqual"    style="@style/KeyStyle" android:text="="/>
            <Button android:id="@+id/keyColon"    style="@style/KeyStyle" android:text=":"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp">

            <Button
                android:id="@+id/keyABC"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.6"
                android:text="ABC"
                android:textColor="#FFFFFF"
                android:background="@drawable/key_special_bg"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/keyQuote"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="&quot;"
                android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg"
                android:textSize="16sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/keySpaceSymbol"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="4"
                android:text="Space"
                android:textColor="#888888"
                android:background="@drawable/key_space_bg"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/keyComma"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.9"
                android:text=","
                android:textColor="#FFFFFF"
                android:background="@drawable/key_normal_bg"
                android:textSize="18sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <ImageButton
                android:id="@+id/keyEnterSymbol"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.8"
                android:src="@drawable/ic_enter"
                android:scaleType="centerInside"
                android:contentDescription="Enter"
                android:background="@drawable/key_enter_bg"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:padding="8dp"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
