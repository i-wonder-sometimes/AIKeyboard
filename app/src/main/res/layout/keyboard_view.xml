<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#000000"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#000000"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBlock1"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="⬛⬛\n⬛⬛"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_gold_border"
            android:layout_marginEnd="4dp"
            android:padding="2dp"/>

        <Button
            android:id="@+id/btnBlock2"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="✏️"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_gold_border"
            android:layout_marginEnd="4dp"
            android:padding="2dp"/>

        <Button
            android:id="@+id/btnBlock3"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="🌐"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_gold_border"
            android:layout_marginEnd="4dp"
            android:padding="2dp"/>

        <Button
            android:id="@+id/btnBlock4"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="🎤"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_gold_border"
            android:layout_marginEnd="0dp"
            android:padding="2dp"/>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvKeyboardLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI ⌨"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginStart="6dp"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelCopiedText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D0D0D"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Copied Message"
            android:textColor="#FFD700"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvCopiedTextInline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:background="#1A1A1A"
            android:padding="10dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Text seen ✓"
                android:textColor="#FFD700"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnClosePanelInline"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="✕ Close"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_gold_border"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="3dp"
        android:paddingEnd="3dp"
        android:paddingTop="4dp">

        <Button android:id="@+id/keyA" style="@style/KeyStyle" android:text="a"/>
        <Button android:id="@+id/keyZ" style="@style/KeyStyle" android:text="z"/>
        <Button android:id="@+id/keyE" style="@style/KeyStyle" android:text="e"/>
        <Button android:id="@+id/keyR" style="@style/KeyStyle" android:text="r"/>
        <Button android:id="@+id/keyT" style="@style/KeyStyle" android:text="t"/>
        <Button android:id="@+id/keyY" style="@style/KeyStyle" android:text="y"/>
        <Button android:id="@+id/keyU" style="@style/KeyStyle" android:text="u"/>
        <Button android:id="@+id/keyI" style="@style/KeyStyle" android:text="i"/>
        <Button android:id="@+id/keyO" style="@style/KeyStyle" android:text="o"/>
        <Button android:id="@+id/keyP" style="@style/KeyStyle" android:text="p"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp">

        <Button android:id="@+id/keyQ" style="@style/KeyStyle" android:text="q"/>
        <Button android:id="@+id/keyS" style="@style/KeyStyle" android:text="s"/>
        <Button android:id="@+id/keyD" style="@style/KeyStyle" android:text="d"/>
        <Button android:id="@+id/keyF" style="@style/KeyStyle" android:text="f"/>
        <Button android:id="@+id/keyG" style="@style/KeyStyle" android:text="g"/>
        <Button android:id="@+id/keyH" style="@style/KeyStyle" android:text="h"/>
        <Button android:id="@+id/keyJ" style="@style/KeyStyle" android:text="j"/>
        <Button android:id="@+id/keyK" style="@style/KeyStyle" android:text="k"/>
        <Button android:id="@+id/keyL" style="@style/KeyStyle" android:text="l"/>
        <Button android:id="@+id/keyM" style="@style/KeyStyle" android:text="m"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="3dp"
        android:paddingEnd="3dp"
        android:paddingTop="4dp">

        <Button
            android:id="@+id/keyShift"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:text="⇧"
            android:textColor="#FFFFFF"
            android:background="@drawable/key_special_bg"
            android:textSize="16sp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"/>

        <Button android:id="@+id/keyW" style="@style/KeyStyle" android:text="w"/>
        <Button android:id="@+id/keyX" style="@style/KeyStyle" android:text="x"/>
        <Button android:id="@+id/keyC" style="@style/KeyStyle" android:text="c"/>
        <Button android:id="@+id/keyV" style="@style/KeyStyle" android:text="v"/>
        <Button android:id="@+id/keyB" style="@style/KeyStyle" android:text="b"/>
        <Button android:id="@+id/keyN" style="@style/KeyStyle" android:text="n"/>
        <Button android:id="@+id/keyApostrophe" style="@style/KeyStyle" android:text="'"/>

        <Button
            android:id="@+id/keyBackspace"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:text="⌫"
            android:textColor="#FFFFFF"
            android:background="@drawable/key_special_bg"
            android:textSize="16sp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:paddingStart="3dp"
        android:paddingEnd="3dp"
        android:paddingTop="4dp">

        <Button
            android:id="@+id/keyNumbers"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:text="?123"
            android:textColor="#FFFFFF"
            android:background="@drawable/key_special_bg"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"/>

        <Button
            android:id="@+id/keyEmoji"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="☺"
            android:textColor="#FFFFFF"
            android:background="@drawable/key_special_bg"
            android:textSize="16sp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"/>

        <Button
            android:id="@+id/keyGlobe"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🌐"
            android:textColor="#FFFFFF"
            android:background="@drawable/key_special_bg"
            android:textSize="14sp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"/>

        <Button
            android:id="@+id/keySpace"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:text="English"
            android:textColor="#AAAAAA"
            android:background="@drawable/key_space_bg"
            android:textSize="13sp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"/>

        <Button
            android:id="@+id/keyPeriod"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.8"
            android:text="."
            android:textColor="#FFFFFF"
            android:background="@drawable/key_normal_bg"
            android:textSize="16sp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"/>

        <Button
            android:id="@+id/keyEnter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.8"
            android:text="↵"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_gold_border"
            android:textSize="18sp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"/>

    </LinearLayout>

</LinearLayout>
