<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⌨️"
        android:textSize="64sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI Keyboard"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smart replies. Right from your keyboard."
        android:textColor="#888888"
        android:textSize="14sp"
        android:layout_marginBottom="48dp"/>

    <!-- Step 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#16213E"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="1"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/btn_ai_bg"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enable AI Keyboard in Settings → Language &amp; Input"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:layout_marginStart="12dp"
            android:layout_gravity="center_vertical"/>
    </LinearLayout>

    <!-- Step 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#16213E"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="2"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/btn_ai_bg"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select AI Keyboard as your default keyboard"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:layout_marginStart="12dp"
            android:layout_gravity="center_vertical"/>
    </LinearLayout>

    <!-- Step 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#16213E"
        android:padding="16dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="3"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/btn_ai_bg"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Copy any message → tap ✨ Reply button on keyboard"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:layout_marginStart="12dp"
            android:layout_gravity="center_vertical"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnEnableKeyboard"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Enable Keyboard in Settings →"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_ai_bg"
        android:textSize="15sp"/>

</LinearLayout>
