<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Copied Message"
        android:textColor="#E94560"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <!-- Copied text bubble -->
    <TextView
        android:id="@+id/tvCopiedText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#CCCCCC"
        android:textSize="15sp"
        android:background="#16213E"
        android:padding="14dp"
        android:layout_marginBottom="20dp"/>

    <!-- Reply label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💬 Reply:"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginBottom="6dp"/>

    <!-- Reply bubble -->
    <TextView
        android:id="@+id/tvAiReply"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Text seen! ✅"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="#0F3460"
        android:padding="14dp"
        android:layout_marginBottom="24dp"/>

    <!-- Close button -->
    <Button
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Close"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_ai_bg"/>

</LinearLayout>
